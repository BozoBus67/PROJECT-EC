# Linguist overrides — controls what shows up in GitHub's language bar and
# which language labels pinned repos. Without this file the detection runs on
# raw byte count across the whole tree, which lets archived old project
# versions, lockfiles, and SVG assets tip the result toward whichever language
# happens to win that byte-count race — usually not the substantive work.
#
# Reference: https://github.com/github-linguist/linguist/blob/main/docs/overrides.md

# Old project versions kept for history, not actively maintained. Mark as
# vendored so they don't dilute the stats.
archived/** linguist-vendored=true

# Package-manager lockfiles. Linguist already treats package-lock.json as
# generated by default; being explicit doesn't hurt and covers the others.
**/package-lock.json linguist-generated=true
**/yarn.lock         linguist-generated=true
**/Cargo.lock        linguist-generated=true
**/Gemfile.lock      linguist-generated=true
**/go.sum            linguist-generated=true

# Built / bundled output — never source. .gitignored today, but if any ever
# leaks into a commit this prevents it skewing the language stats.
**/dist/**  linguist-generated=true
**/build/** linguist-generated=true

# SVG counts as a language in Linguist (XML-flavored). The gemstone variant's
# scroll faces would otherwise show up in the bar even though they're assets,
# not source. Strip them from detection.
*.svg linguist-detectable=false
